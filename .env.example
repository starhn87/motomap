EXPO_PUBLIC_SUPABASE_URL=your_supabase_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NAVER_MAP_CLIENT_ID=your_naver_map_client_id
EXPO_PUBLIC_NAVER_CLIENT_ID=your_naver_client_id
EXPO_PUBLIC_NAVER_CLIENT_SECRET=your_naver_client_secret

# 카카오 네이티브 앱 키 (developers.kakao.com)
KAKAO_NATIVE_APP_KEY=your_kakao_native_app_key

# 카카오 REST API 키 (제보 주소 검색 — 카카오 개발자 콘솔 > 내 앱 > 앱 키 > REST API 키)
EXPO_PUBLIC_KAKAO_REST_API_KEY=your_kakao_rest_api_key

# 시드 스크립트(scripts/seed-bike-cafes.mjs) 실행 시에만 필요
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
ADMIN_USER_ID=optional_admin_user_uuid

# Sentry 에러 추적 (sentry.io 프로젝트 생성 후 발급)
EXPO_PUBLIC_SENTRY_DSN=https://xxx@oXXX.ingest.sentry.io/XXX
SENTRY_ORG=your_sentry_org_slug
SENTRY_PROJECT=ridemap
